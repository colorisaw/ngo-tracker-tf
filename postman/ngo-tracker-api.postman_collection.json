                  "const json = pm.response.json();",
                  "pm.test('Returns ngo_id', () => {",
                  "    pm.expect(json.ngo).to.have.property('ngo_id');",
                  "});",
                  "if (json.ngo && json.ngo.ngo_id) {",
                  "    pm.collectionVariables.set('ngo_id', json.ngo.ngo_id);",
                  "    if (pm.environment.name) {",
                  "        pm.environment.set('ngo_id', json.ngo.ngo_id);",
