      "item": [
        {
          "name": "GET / — Health check",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Service ok', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.ok).to.eql(true);",
